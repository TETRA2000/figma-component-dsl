{
  "name": "figma-component-dsl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build -w packages/plugin",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "bin": {
    "figma-dsl": "bin/figma-dsl",
    "figma-dsl-compile": "bin/figma-dsl-compile",
    "figma-dsl-render": "bin/figma-dsl-render",
    "figma-dsl-capture": "bin/figma-dsl-capture",
    "figma-dsl-compare": "bin/figma-dsl-compare",
    "figma-dsl-pipeline": "bin/figma-dsl-pipeline",
    "figma-dsl-export": "bin/figma-dsl-export",
    "figma-dsl-generate-test-suite": "bin/figma-dsl-generate-test-suite",
    "figma-dsl-batch": "bin/figma-dsl-batch",
    "figma-dsl-batch-compare": "bin/figma-dsl-batch-compare",
    "figma-dsl-capture-figma": "bin/figma-dsl-capture-figma",
    "figma-dsl-calibrate": "bin/figma-dsl-calibrate",
    "figma-dsl-validate": "bin/figma-dsl-validate",
    "figma-dsl-sync": "bin/figma-dsl-sync"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  }
}
